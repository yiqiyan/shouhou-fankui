<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.huahai.mapper.HHSysRoleMapper">

    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        role_id, role_name, role_code, status, create_time
    </sql>

    <!-- 根据角色ID查询角色 -->
    <select id="selectRoleById" resultType="cn.huahai.entity.HHSysRole">
        SELECT <include refid="Base_Column_List" />
        FROM hh_sys_role
        WHERE role_id = #{roleId} AND status = 1
    </select>

    <!-- 查询所有启用的角色 -->
    <select id="selectAllRoles" resultType="cn.huahai.entity.HHSysRole">
        SELECT <include refid="Base_Column_List" />
        FROM hh_sys_role
        WHERE status = 1
        ORDER BY role_id ASC
    </select>

    <!-- 查询角色关联的菜单ID -->
    <select id="selectMenuIdsByRoleId" resultType="java.lang.Integer">
        SELECT menu_id
        FROM hh_sys_role_menu
        WHERE role_id = #{roleId}
    </select>

</mapper>